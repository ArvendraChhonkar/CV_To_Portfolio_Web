extends main_style_template.pug

block headers
    link(rel="stylesheet", href="/Styles/main.css")
    script(src="https://cdn.tailwindcss.com")

block content
    .min-h-screen.flex.items-center.justify-center.bg-gray-100.p-6
        .max-w-2xl.w-full.bg-white.shadow-lg.rounded-2xl.p-8.text-center
            .mb-6
                div.mx-auto.flex.items-center.justify-center.h-16.w-16.rounded-full.bg-green-100
                    svg.h-10.w-10.text-green-600(fill="none", stroke="currentColor", viewBox="0 0 24 24")
                        path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M5 13l4 4L19 7")
            
            h1.text-3xl.font-bold.text-gray-800.mb-2 Success!
            p.text-gray-600.mb-8 Your professional portfolio has been generated.

            .bg-gray-50.rounded-lg.p-4.mb-8.text-left.border.border-gray-200
                p.text-xs.font-mono.uppercase.tracking-widest.mb-2.text-gray-400 System Output Path:
                p.text-sm.font-mono.text-blue-600.break-all #{outputPath}

            //- FIX: Use class="" for Tailwind responsive prefixes
            div(class="flex flex-col sm:flex-row gap-4 justify-center")
                a(class="flex-1 bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-blue-700 transition-colors" href=downloadUrl target="_blank") View Portfolio
                a(class="flex-1 bg-gray-800 text-white px-6 py-3 rounded-xl font-semibold hover:bg-gray-900 transition-colors" href=downloadUrl download=fileName) Download HTML

            .mt-8
                a.text-sm.text-gray-500(href="/") ← Create another portfolio